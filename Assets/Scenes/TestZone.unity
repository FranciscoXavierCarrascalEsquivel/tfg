  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  lines:
  - text: Quin cercle tan bonic!
    portrait: {fileID: 6542110693660499982, guid: 87130bbdffa07264e9d4bbd49c4a2ab6, type: 3}
    portraitAnimator: {fileID: 0}
  - text: 'Em recorda a una pilota de ping pong... '
    portrait: {fileID: -4083144000507761819, guid: 87130bbdffa07264e9d4bbd49c4a2ab6, type: 3}
    portraitAnimator: {fileID: 0}
  - text: Pero d'un tamany bastant mes gran, la veritat!
    portrait: {fileID: -4083144000507761819, guid: 87130bbdffa07264e9d4bbd49c4a2ab6, type: 3}
    portraitAnimator: {fileID: 0}
  description: 
  portrait: {fileID: -4083144000507761819, guid: 87130bbdffa07264e9d4bbd49c4a2ab6, type: 3}
  portraitAnimator: {fileID: 0}
