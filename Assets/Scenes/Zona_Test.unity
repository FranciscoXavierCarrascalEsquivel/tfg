        m_PersistentCalls:
          m_Calls: []
    - text: If you go to the west, you will arrive to my food cart. I encourage you
        to come to visit me! You might find something interesting.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
