  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: Hey! You! Yeah, you! If you're reading this, you're already late.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 0
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'The exit is to the north-east. Easy.

'
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 0
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: (There's no way you can get lost in a maze, right?)
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: ...right?
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
