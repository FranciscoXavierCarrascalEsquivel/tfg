    portraitAnimator: {fileID: 0}
    interactableSpriteChange: {fileID: 0}
    interactableSpriteChangeSound: {fileID: 0}
    owner: {fileID: 0}
    isEndNode: 1
    delayBeforeLine: 0
    autoAdvanceTime: 0
    setNextInteractionVersion: -1
    jumpToLineIndex: -1
    choices: []
    onLineReached:
      m_PersistentCalls:
        m_Calls: []
  - text: It's fine, whenever you need help, I'm around. It's not like I have opcio
      de moure'm...
