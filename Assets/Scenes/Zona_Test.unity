      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: '"If you read this, please, don''t head to the west, you will die! I
        swear! There''s a big lake full of piranhas! Take care of yourself!"'
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
