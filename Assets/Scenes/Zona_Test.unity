--- !u!114 &254162696
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 254162691}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb2d6eff02e32c94ebdcb258226edc4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: Oh! A customer. This is already suspicious...
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Welcome to my totally normal and emotionally stable SALAD CART!
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'We have lettuce. More lettuce and...

'
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: ...surprise, lettuce.
      portrait: {fileID: 1259515000763965448, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You look like someone who makes eye contact with vegetables. I respect
        that.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So...bad news. I am closing!
      portrait: {fileID: 2309193914379153405, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Good news. I am also terrible at inventory management.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Which means... This salad has been staring at me for 6 hours.
      portrait: {fileID: 2309193914379153405, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'And now it can stare at YOU. '
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Take it, please.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You recieved a Cat Salad.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: a0b83e19ae49a324a8b5c22a0f913b28, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 1065926568238121273, guid: af916aeb94ef3f94d979abd6efa70d3d, type: 3}
      interactableSpriteChangeSound: {fileID: 8300000, guid: d83bf5ab2d95cb240a9cc5878c7412c6, type: 3}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 662989802}
            m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
            m_MethodName: AddItem
            m_Mode: 5
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: Cat Salad
              m_BoolArgument: 0
            m_CallState: 1
    - text: Don't worry, it is fresh...
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 8300000, guid: d83bf5ab2d95cb240a9cc5878c7412c6, type: 3}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Emotionally fresh.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 8300000, guid: d83bf5ab2d95cb240a9cc5878c7412c6, type: 3}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: If it moves, that means it's organic.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: if it talks, that means i should run.
      portrait: {fileID: 1259515000763965448, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: "You\u2019re probably wondering why i\u2019m still here."
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: I live here.
      portrait: {fileID: 2309193914379153405, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: I don't really have other options.
      portrait: {fileID: 730722548152664613, guid: e786b208bf11f124cb7f181be4792130, type: 3}
      speakerName: 
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 929b279316cde034397ae72a018bbcd2, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  description: "\u2026"
  portrait: {fileID: 0}
  portraitAnimator: {fileID: 0}
