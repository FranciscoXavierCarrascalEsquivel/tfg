  m_Script: {fileID: 11500000, guid: eb2d6eff02e32c94ebdcb258226edc4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: It is a wooden chest. Do you open it?
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices:
      - text: Yes
        jumpToLineIndex: 1
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: No
        jumpToLineIndex: 2
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You obtained a Watermelon Candy.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: -572116840169555268, guid: 0b394a2991b86904887b4bd24cc85e04, type: 3}
      interactableSpriteChangeSound: {fileID: 8300000, guid: 672194ff7cec6cf498f66778fb76ff08, type: 3}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 662989802}
            m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
            m_MethodName: AddItem
            m_Mode: 5
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: Watermelon Candy
              m_BoolArgument: 0
            m_CallState: 1
    - text: You think that tresure could be the property of another person... We
        should keep it closed to respect its privicy.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 2
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: It is an empty chest.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: Is the same chest you refused to open before... Will you open it now?
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices:
      - text: Yes
        jumpToLineIndex: 1
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls:
            - m_Target: {fileID: 662989802}
              m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
              m_MethodName: AddItem
              m_Mode: 5
              m_Arguments:
                m_ObjectArgument: {fileID: 0}
                m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
                m_IntArgument: 0
                m_FloatArgument: 0
                m_StringArgument: Watermelon Candy
                m_BoolArgument: 0
              m_CallState: 2
      - text: No
        jumpToLineIndex: 2
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You obtained a Watermelon Candy.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: -572116840169555268, guid: 0b394a2991b86904887b4bd24cc85e04, type: 3}
      interactableSpriteChangeSound: {fileID: 8300000, guid: 672194ff7cec6cf498f66778fb76ff08, type: 3}
      owner: {fileID: 0}
