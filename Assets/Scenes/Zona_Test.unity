      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: Is the same chest you refused to open before... Will you open it now?
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
