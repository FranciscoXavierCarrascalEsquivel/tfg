  versions:
  - lines:
    - text: 'Is a wooden sign, it says the following... '
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
