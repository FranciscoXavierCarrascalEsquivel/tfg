  m_Script: {fileID: 11500000, guid: eb2d6eff02e32c94ebdcb258226edc4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: There's a big rock blocking the way...
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Well, actually not, you can probably continue walking next to it.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: It is just a big rock.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: 1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Oh wait, I can see a rock shard that I could take. Should I?
      portrait: {fileID: -3536576362103274770, guid: 2e7c0dd8201442841a0027ffea89ede9, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: 1
      choices:
      - text: Yes
        jumpToLineIndex: 2
        customSelectSound: {fileID: 8300000, guid: 672194ff7cec6cf498f66778fb76ff08, type: 3}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls:
            - m_Target: {fileID: 662989802}
              m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
              m_MethodName: AddItem
              m_Mode: 5
              m_Arguments:
                m_ObjectArgument: {fileID: 0}
                m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
                m_IntArgument: 0
                m_FloatArgument: 0
                m_StringArgument: Rock
                m_BoolArgument: 0
              m_CallState: 2
      - text: No
        jumpToLineIndex: 3
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You obtained a Rock.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 2
      jumpToLineIndex: 1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You decide that there are better things to do right now.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
