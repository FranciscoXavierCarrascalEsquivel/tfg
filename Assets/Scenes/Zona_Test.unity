      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'The sign is signed, but you can''t identify the characters because it
        is in poor conditions... '
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
