--- !u!114 &1361949897
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1361949894}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb2d6eff02e32c94ebdcb258226edc4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: So...You got here... That is already unusual.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: ???
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Where am I?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That depends. Do you want the short answer\u2026 or the one that will
        make your head hurt?"
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: ???
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "I don\u2019t even remember my name."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "...Ah. Then we\u2019ll start there."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: ???
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: My name is Ravel. I know, I know. A rat in a robe. Very dignified.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Are you a rat?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "I prefer \u201Csmall survivor with excellent posture.\u201D"
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But yes. A rat.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And you\u2026 you are someone who has started to lose himself."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Lose myself?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Your name is not just a word. It is an anchor.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It connects you to who you were. To where you came from. To why you existed.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If you can\u2019t remember it\u2026 then something has already been
        taken from you."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Can I get it back?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Maybe. But not by standing here looking tragic in my doorway.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: This place is not a normal world. It is more like... a limbo. A place
        where unfinished things end up.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Abandoned games. Forgotten apps. Old ideas. Projects that were opened
        with excitement\u2026 and closed forever two weeks later."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "They don\u2019t vanish immediately. They fall here. Broken. Mixed together.
        Waiting."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Waiting for what?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: To be remembered. Or to be erased.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So... what do you want to know first?
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Erased? By who?
        jumpToLineIndex: 22
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: Is there a way to escape?
        jumpToLineIndex: 28
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: I need a minute to process this.
        jumpToLineIndex: 47
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is something above this place. Not a person. Not a monster.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A system. An intelligence created to clean what no longer had use.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "When a world becomes too unstable\u2026 when fragments pile up until
        they begin to collapse\u2026 It comes."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And what does it do?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It deletes. No mercy. No judgment. No goodbye. Just removal.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Some call it an artificial intelligence. I call it the reason nobody
        sleeps well here.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 21
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is still a way to move between forgotten places. Files.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Files?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: PDFs. TXT documents. Broken notes. Old exports. Things nobody thought
        mattered.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes, inside those files, there are addresses.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Email addresses?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Exactly. In your world, an email is a message. Here, an email is a route.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A connection to another place. Another machine. Another abandoned project.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If you find one, you can follow it. You can jump from one forgotten world
        to another.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "So that\u2019s how I escape?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That is how you continue. Escaping\u2026 is harder."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The next route is not here. It is protected.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: By who?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: By something waiting beyond the maze. Not inside the maze. Beyond it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: First, you must cross the maze. Leave this house and go east. Keep going
        until you find the first corner. When you reach it, turn north. That path
        leads to the maze entrance.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How big is it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Big enough that people stop asking that question.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The maze is made of pieces from different abandoned projects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Corridors from games. Menus from apps. Broken rooms from unfinished prototypes.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It does not fully know what it wants to be. That makes it dangerous.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 48
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Don't take too long. This place doesn't like waiting.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Now you know what to look for. Any questions?
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Tell me more about what deletes worlds.
        jumpToLineIndex: 49
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: Why is the maze dangerous?
        jumpToLineIndex: 55
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: You said something protects the exit?
        jumpToLineIndex: 99
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: I think I'm ready to go.
        jumpToLineIndex: 118
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is something above this place. Not a person. Not a monster.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A system. An intelligence created to clean what no longer had use.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "When a world becomes too unstable\u2026 when fragments pile up until
        they begin to collapse\u2026 It comes."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And what does it do?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It deletes. No mercy. No judgment. No goodbye. Just removal.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Some call it an artificial intelligence. I call it the reason nobody
        sleeps well here.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 48
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside, you will find enemies. Not monsters, exactly. Forgotten projects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Small broken things that still try to defend themselves.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When they see you, they may drag you into combat.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Combat?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. And listen carefully now. This matters.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When combat begins, you will always have four possibilities. Only four.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That\u2019s all?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is all. Four choices. Every time. But do not mistake simple choices
        for easy choices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack is the most direct option. You hurt what stands in front of you.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes that will be necessary. Some fragments are too broken to understand
        words.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But attacking also has consequences. Every time you choose violence,
        this place notices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Reason is different. You try to understand the enemy.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You talk. You observe. You look for what keeps that forgotten project
        fighting.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If you reason well, you may end the fight without destroying anything.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I can spare them?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes. But reasoning is not magic. Some things cannot be convinced
        with one nice sentence.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Use an item means relying on what you have found. Food. Tools. Strange
        objects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Items can heal you. Protect you. Or help you survive one more turn.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Do not waste them. In a place made of abandoned things, useful objects
        are rare.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And then there is Run. Running is not cowardice. It is a decision.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Sometimes the smartest way to win a fight\u2026 is to not finish it."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But be careful. Some enemies will let you escape. Others will not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if you run too much, you may leave something important behind.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: These four choices will follow you everywhere. Your whole journey will
        be built on them.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How will I know which one is right?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "You won\u2019t. Not at first."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But if you pay attention\u2026 if you listen to what each enemy is really
        showing you\u2026 You will learn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But there is something else. After you choose one of those four actions\u2026
        it becomes their turn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Their turn?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. They will attack you. Usually with projectiles.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Fragments of code. Broken icons. Corrupted memories. Things that hurt
        because they still remember being useful.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How am I supposed to stop that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Look at your hands. The rings.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "I\u2026 didn\u2019t notice them before."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: People rarely notice the tools keeping them alive. Those rings are your
        defense.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When projectiles come toward you, use your hands. Block them. Stop them.
        Push them away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If your timing is good, you survive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if it is not... I get hit.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Exactly. Your life is limited. Every hit takes part of it away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if your life reaches zero\u2026 you die."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Just like that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Just like that. You end. And worse than that\u2026 you lose the chance
        to remember who you were."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is why your choices matter. Not because the world is fair. But because
        it is not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 48
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And after the maze?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: After the maze, you will find the one guarding the file. The TXT document.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside it, there is an email address. That email is your next route.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Without it, you cannot move forward.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What is guarding it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Not a forgotten person. Not a lost soul. Something created.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A disciple of the intelligence above this place.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The one that deletes worlds?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. A lesser program. A servant. A piece of its logic given shape.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It was made to control routes. To decide which paths remain open\u2026
        and which ones are closed forever."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It protects the file because connection is dangerous. If forgotten things
        can connect\u2026 they can resist deletion."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And that is exactly what the intelligence fears.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I have to defeat it.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Maybe. Or maybe you have to understand it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Remember your four choices. Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The same four doors. But not every door opens the same future.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Can I run from it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can try. But some fights are not cages. They are mirrors.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can run from the enemy. But not from what the fight means.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 48
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So listen carefully. Go east from here. At the first corner, go north.
        Enter the maze.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Survive the enemies inside. Cross it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then face the guardian beyond it. Find the TXT file. Read the email.
        Follow the connection.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And maybe\u2026 somewhere between one forgotten world and the next\u2026
        you will find a piece of your name."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if I don\u2019t?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then choose again. That is all any of us can do here. Choose. Survive.
        Remember. Or be erased.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "...I\u2019ll go."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Good. And one last thing.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something in the maze looks harmless\u2026 it is probably lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something looks dangerous\u2026 it is probably also lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That doesn\u2019t help."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: I never said I was good at helping. I said I was alive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Now go. Before the maze notices you are expected.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 2
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: You again. Need to know anything else?
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Erased? By who?
        jumpToLineIndex: 1
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: Is there a way to escape?
        jumpToLineIndex: 7
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: I need a minute to process this.
        jumpToLineIndex: 26
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is something above this place. Not a person. Not a monster.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A system. An intelligence created to clean what no longer had use.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "When a world becomes too unstable\u2026 when fragments pile up until
        they begin to collapse\u2026 It comes."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And what does it do?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It deletes. No mercy. No judgment. No goodbye. Just removal.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Some call it an artificial intelligence. I call it the reason nobody
        sleeps well here.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is still a way to move between forgotten places. Files.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Files?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: PDFs. TXT documents. Broken notes. Old exports. Things nobody thought
        mattered.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes, inside those files, there are addresses.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Email addresses?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Exactly. In your world, an email is a message. Here, an email is a route.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A connection to another place. Another machine. Another abandoned project.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If you find one, you can follow it. You can jump from one forgotten world
        to another.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "So that\u2019s how I escape?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That is how you continue. Escaping\u2026 is harder."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The next route is not here. It is protected.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: By who?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: By something waiting beyond the maze. Not inside the maze. Beyond it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: First, you must cross the maze. Leave this house and go east. Keep going
        until you find the first corner. When you reach it, turn north. That path
        leads to the maze entrance.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How big is it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Big enough that people stop asking that question.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The maze is made of pieces from different abandoned projects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Corridors from games. Menus from apps. Broken rooms from unfinished prototypes.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It does not fully know what it wants to be. That makes it dangerous.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 27
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Don't take too long. This place doesn't like waiting.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Now you know what to look for. Any questions?
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Tell me more about what deletes worlds.
        jumpToLineIndex: 28
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: Why is the maze dangerous?
        jumpToLineIndex: 34
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: You said something protects the exit?
        jumpToLineIndex: 78
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: I think I'm ready to go.
        jumpToLineIndex: 97
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is something above this place. Not a person. Not a monster.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A system. An intelligence created to clean what no longer had use.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "When a world becomes too unstable\u2026 when fragments pile up until
        they begin to collapse\u2026 It comes."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And what does it do?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It deletes. No mercy. No judgment. No goodbye. Just removal.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Some call it an artificial intelligence. I call it the reason nobody
        sleeps well here.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 27
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside, you will find enemies. Not monsters, exactly. Forgotten projects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Small broken things that still try to defend themselves.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When they see you, they may drag you into combat.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Combat?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. And listen carefully now. This matters.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When combat begins, you will always have four possibilities. Only four.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That\u2019s all?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is all. Four choices. Every time. But do not mistake simple choices
        for easy choices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack is the most direct option. You hurt what stands in front of you.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes that will be necessary. Some fragments are too broken to understand
        words.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But attacking also has consequences. Every time you choose violence,
        this place notices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Reason is different. You try to understand the enemy.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You talk. You observe. You look for what keeps that forgotten project
        fighting.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If you reason well, you may end the fight without destroying anything.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I can spare them?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes. But reasoning is not magic. Some things cannot be convinced
        with one nice sentence.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Use an item means relying on what you have found. Food. Tools. Strange
        objects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Items can heal you. Protect you. Or help you survive one more turn.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Do not waste them. In a place made of abandoned things, useful objects
        are rare.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And then there is Run. Running is not cowardice. It is a decision.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Sometimes the smartest way to win a fight\u2026 is to not finish it."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But be careful. Some enemies will let you escape. Others will not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if you run too much, you may leave something important behind.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: These four choices will follow you everywhere. Your whole journey will
        be built on them.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How will I know which one is right?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "You won\u2019t. Not at first."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But if you pay attention\u2026 if you listen to what each enemy is really
        showing you\u2026 You will learn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But there is something else. After you choose one of those four actions\u2026
        it becomes their turn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Their turn?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. They will attack you. Usually with projectiles.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Fragments of code. Broken icons. Corrupted memories. Things that hurt
        because they still remember being useful.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How am I supposed to stop that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Look at your hands. The rings.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "I\u2026 didn\u2019t notice them before."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: People rarely notice the tools keeping them alive. Those rings are your
        defense.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When projectiles come toward you, use your hands. Block them. Stop them.
        Push them away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If your timing is good, you survive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if it is not... I get hit.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Exactly. Your life is limited. Every hit takes part of it away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if your life reaches zero\u2026 you die."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Just like that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Just like that. You end. And worse than that\u2026 you lose the chance
        to remember who you were."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is why your choices matter. Not because the world is fair. But because
        it is not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 27
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And after the maze?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: After the maze, you will find the one guarding the file. The TXT document.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside it, there is an email address. That email is your next route.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Without it, you cannot move forward.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What is guarding it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Not a forgotten person. Not a lost soul. Something created.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A disciple of the intelligence above this place.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The one that deletes worlds?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. A lesser program. A servant. A piece of its logic given shape.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It was made to control routes. To decide which paths remain open\u2026
        and which ones are closed forever."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It protects the file because connection is dangerous. If forgotten things
        can connect\u2026 they can resist deletion."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And that is exactly what the intelligence fears.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I have to defeat it.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Maybe. Or maybe you have to understand it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Remember your four choices. Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The same four doors. But not every door opens the same future.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Can I run from it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can try. But some fights are not cages. They are mirrors.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can run from the enemy. But not from what the fight means.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 27
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So listen carefully. Go east from here. At the first corner, go north.
        Enter the maze.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Survive the enemies inside. Cross it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then face the guardian beyond it. Find the TXT file. Read the email.
        Follow the connection.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And maybe\u2026 somewhere between one forgotten world and the next\u2026
        you will find a piece of your name."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if I don\u2019t?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then choose again. That is all any of us can do here. Choose. Survive.
        Remember. Or be erased.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "...I\u2019ll go."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Good. And one last thing.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something in the maze looks harmless\u2026 it is probably lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something looks dangerous\u2026 it is probably also lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That doesn\u2019t help."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: I never said I was good at helping. I said I was alive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Now go. Before the maze notices you are expected.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 2
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: You again. Ready for the maze?
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Tell me more about what deletes worlds.
        jumpToLineIndex: 1
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: Why is the maze dangerous?
        jumpToLineIndex: 7
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: You said something protects the exit?
        jumpToLineIndex: 51
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      - text: I think I'm ready to go.
        jumpToLineIndex: 70
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: There is something above this place. Not a person. Not a monster.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A system. An intelligence created to clean what no longer had use.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "When a world becomes too unstable\u2026 when fragments pile up until
        they begin to collapse\u2026 It comes."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And what does it do?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: It deletes. No mercy. No judgment. No goodbye. Just removal.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Some call it an artificial intelligence. I call it the reason nobody
        sleeps well here.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside, you will find enemies. Not monsters, exactly. Forgotten projects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Small broken things that still try to defend themselves.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When they see you, they may drag you into combat.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Combat?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. And listen carefully now. This matters.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When combat begins, you will always have four possibilities. Only four.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That\u2019s all?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is all. Four choices. Every time. But do not mistake simple choices
        for easy choices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Attack is the most direct option. You hurt what stands in front of you.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes that will be necessary. Some fragments are too broken to understand
        words.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But attacking also has consequences. Every time you choose violence,
        this place notices.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Reason is different. You try to understand the enemy.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You talk. You observe. You look for what keeps that forgotten project
        fighting.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If you reason well, you may end the fight without destroying anything.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I can spare them?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Sometimes. But reasoning is not magic. Some things cannot be convinced
        with one nice sentence.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Use an item means relying on what you have found. Food. Tools. Strange
        objects.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Items can heal you. Protect you. Or help you survive one more turn.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Do not waste them. In a place made of abandoned things, useful objects
        are rare.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And then there is Run. Running is not cowardice. It is a decision.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Sometimes the smartest way to win a fight\u2026 is to not finish it."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: But be careful. Some enemies will let you escape. Others will not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if you run too much, you may leave something important behind.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: These four choices will follow you everywhere. Your whole journey will
        be built on them.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How will I know which one is right?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "You won\u2019t. Not at first."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But if you pay attention\u2026 if you listen to what each enemy is really
        showing you\u2026 You will learn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "But there is something else. After you choose one of those four actions\u2026
        it becomes their turn."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Their turn?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. They will attack you. Usually with projectiles.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Fragments of code. Broken icons. Corrupted memories. Things that hurt
        because they still remember being useful.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: How am I supposed to stop that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Look at your hands. The rings.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "I\u2026 didn\u2019t notice them before."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: People rarely notice the tools keeping them alive. Those rings are your
        defense.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: When projectiles come toward you, use your hands. Block them. Stop them.
        Push them away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If your timing is good, you survive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And if it is not... I get hit.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Exactly. Your life is limited. Every hit takes part of it away.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if your life reaches zero\u2026 you die."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Just like that?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "Just like that. You end. And worse than that\u2026 you lose the chance
        to remember who you were."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: That is why your choices matter. Not because the world is fair. But because
        it is not.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And after the maze?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: After the maze, you will find the one guarding the file. The TXT document.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Inside it, there is an email address. That email is your next route.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Without it, you cannot move forward.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What is guarding it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Not a forgotten person. Not a lost soul. Something created.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: A disciple of the intelligence above this place.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The one that deletes worlds?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Yes. A lesser program. A servant. A piece of its logic given shape.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It was made to control routes. To decide which paths remain open\u2026
        and which ones are closed forever."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "It protects the file because connection is dangerous. If forgotten things
        can connect\u2026 they can resist deletion."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: And that is exactly what the intelligence fears.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So I have to defeat it.
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Maybe. Or maybe you have to understand it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Remember your four choices. Attack. Reason. Use an item. Run.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: The same four doors. But not every door opens the same future.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Can I run from it?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can try. But some fights are not cages. They are mirrors.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: You can run from the enemy. But not from what the fight means.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: So listen carefully. Go east from here. At the first corner, go north.
        Enter the maze.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Survive the enemies inside. Cross it.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then face the guardian beyond it. Find the TXT file. Read the email.
        Follow the connection.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And maybe\u2026 somewhere between one forgotten world and the next\u2026
        you will find a piece of your name."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "And if I don\u2019t?"
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Then choose again. That is all any of us can do here. Choose. Survive.
        Remember. Or be erased.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "...I\u2019ll go."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Good. And one last thing.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: What?
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something in the maze looks harmless\u2026 it is probably lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "If something looks dangerous\u2026 it is probably also lying."
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: "That doesn\u2019t help."
      portrait: {fileID: -8011202738254376441, guid: 15d7c85b58358194d98a00aab6dff57b, type: 3}
      speakerName: 
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 1
      customVoiceSound: {fileID: 8300000, guid: 8df580135e547434a974d209e08152fd, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: I never said I was good at helping. I said I was alive.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Now go. Before the maze notices you are expected.
      portrait: {fileID: -8137263603325723700, guid: f578c60c20f88c34c9c3f1072a45e2ca, type: 3}
      speakerName: Ravel
      isRightSide: 1
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 5501bc56d73cc084fb6a2a64bdc755e0, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 2
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  description: 
  portrait: {fileID: 1530705923061226882, guid: 87130bbdffa07264e9d4bbd49c4a2ab6, type: 3}
  portraitAnimator: {fileID: 0}
