  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: "Okay. Small miscalculation. This is NOT the exit (If you're here, you
        probably messed up too).\n \n"
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 0
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'Good news though! I found a chest! I''ll just stay inside until help
        arrives. It''s actually pretty cozy.

'
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: 1
      jumpToLineIndex: -1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: If it takes too long, I might stop replying.
      portrait: {fileID: 0}
      speakerName: 
      isRightSide: 0
      showOnTop: 0
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: a94df6739b73a494795bc40d1d839b51, type: 3}
