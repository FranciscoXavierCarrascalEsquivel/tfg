  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: eb2d6eff02e32c94ebdcb258226edc4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  versions:
  - lines:
    - text: 'Howdy... I see you are new in this zone... '
      portrait: {fileID: 1321056030923612999, guid: 2ede7e6f222f32446954ce14c359bd8b, type: 3}
      speakerName: ???
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Where are my manners... Sorry, my name's Ledgermole.
      portrait: {fileID: -5915627475654302125, guid: d6cd80c79464ed64eb9e4ae481fe4cbd, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 2
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Maybe you'd be interested in some of my wares. I am conegut per aquestes
        zones per proporcionar OBJECTES de qualitat, vols fer una ullada?
      portrait: {fileID: -5915627475654302125, guid: d6cd80c79464ed64eb9e4ae481fe4cbd, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: -1
      choices:
      - text: Alright!
        jumpToLineIndex: 3
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls:
            - m_Target: {fileID: 662989802}
              m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
              m_MethodName: ShowShopMenu
              m_Mode: 1
              m_Arguments:
                m_ObjectArgument: {fileID: 0}
                m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
                m_IntArgument: 0
                m_FloatArgument: 0
                m_StringArgument: 
                m_BoolArgument: 0
              m_CallState: 2
      - text: No, thanks...
        jumpToLineIndex: 4
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Thanks for your visit! See ya!
      portrait: {fileID: 8000887055239518031, guid: d07f64c2415edd14e80868db9d0b70e7, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: No worries, whenever you need something, just drop by.
      portrait: {fileID: 8000887055239518031, guid: d07f64c2415edd14e80868db9d0b70e7, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 1
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
  - lines:
    - text: Hello again! Interested in any of my wares?
      portrait: {fileID: -5915627475654302125, guid: d6cd80c79464ed64eb9e4ae481fe4cbd, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 0
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices:
      - text: Let me take a look...
        jumpToLineIndex: 1
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls:
            - m_Target: {fileID: 662989802}
              m_TargetAssemblyTypeName: PlayerInventory, Assembly-CSharp
              m_MethodName: ShowShopMenu
              m_Mode: 1
              m_Arguments:
                m_ObjectArgument: {fileID: 0}
                m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
                m_IntArgument: 0
                m_FloatArgument: 0
                m_StringArgument: 
                m_BoolArgument: 0
              m_CallState: 2
      - text: Definitely not...
        jumpToLineIndex: 2
        customSelectSound: {fileID: 0}
        onChoiceSelected:
          m_PersistentCalls:
            m_Calls: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: 'Thanks for your visit, see you soon! '
      portrait: {fileID: 8000887055239518031, guid: d07f64c2415edd14e80868db9d0b70e7, type: 3}
      speakerName: Ledgermole
      isRightSide: 0
      showOnTop: 1
      isThought: 0
      forceReopen: 0
      customVoiceSound: {fileID: 8300000, guid: 6fd30ec752c0a9840ae851bf8efafe80, type: 3}
      portraitAnimator: {fileID: 0}
      interactableSpriteChange: {fileID: 0}
      interactableSpriteChangeSound: {fileID: 0}
      owner: {fileID: 0}
      isEndNode: 1
      delayBeforeLine: 0
      autoAdvanceTime: 0
      setNextInteractionVersion: -1
      jumpToLineIndex: 0
      choices: []
      onLineReached:
        m_PersistentCalls:
          m_Calls: []
    - text: Don
      portrait: {fileID: 0}
      speakerName: 
