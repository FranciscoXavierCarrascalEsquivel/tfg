%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4961ccfa01b95f14ca6b59134965d3cf, type: 3}
  m_Name: BGSkell
  m_EditorClassIdentifier: Assembly-CSharp::SocialBehaviorTree
  playerActions:
  - Ballar
  - Plorar
  - Oferir os
  - Insultar
  - Explicar acudit
  menuHeader: 'Accions disponibles:'
  startNodeId: 0
  friendshipText: Sembles una bona persona, crec que m'he equicovat jutjant-te abans
    de temps... Espero que em perdonis...
  friendGoldMin: 4
  friendGoldMax: 6
  nodes:
  - nodeId: 0
    enemyEntryText: Ei, que fas que no m'ataques?
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: Comences a ballar de forma maldestre el primer que se't ve
        al cap. L'enemic sembla curios per saber que es el que estas fent.
      enemyReactionText: Ei! Que fas? Es alguna mena d'atac especial o que?
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: Et tires al terra i comences a plorar desconsoladament..
        A l'enemic no li sembla importar...
      enemyReactionText: El plor demostra que no ets un guerrer pur de cor... Aixeca't
        i lluita com ha de ser!
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Insultar
      playerActionText: Li dius a l'enemic que no te res de muscul... L'enemic sembla
        confos...
      enemyReactionText: Que es un muscul?
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Oferir os
      playerActionText: Alces amb la teva ma l'os que tenies a l'inventari. Abans
        de que puguis dir res, l'enemic te'l treu de la ma i sembla alegrar-se.
      enemyReactionText: Es un regal? Per a mi? Es lo millor que em podries haver
        donat
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Explicar acudit
      playerActionText: "Li dius a l'enemic en forma d'acudit que els esquelets no
        surten de festa perqu\xE8 no tenen cos per aguantar-ho. Es posa a riure."
      enemyReactionText: HAHAHAHA, quin bon acudit HAHAHA
      nextNodeId: 1
      requiredItem: {fileID: 0}
  - nodeId: 1
    enemyEntryText: HAHAHA, em pixaria a sobre... si pogues HAHAHA
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: Fas uns passos de flamenco, l'enemic queda sorpres i segueix
        rient.
      enemyReactionText: UAU, a sobre que ets bon comediant, tambe saps ballar? Quin
        talent!
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: "Comen\xE7es a plorar despres d'haver fet l'acudit. L'enemic
        s'extranya..."
      enemyReactionText: Ei... tot be? Potser no era un acudit i m'he equivocat...
        Ho sento...
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Oferir os
      playerActionText: Alces amb la teva ma l'os que tenies a l'inventari. Abans
        de que puguis dir res, l'enemic te'l treu de la ma i sembla alegrar-se.
      enemyReactionText: Es un regal? Per a mi? Es lo millor que em podries haver
        donat
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insultar
      playerActionText: Li dius a l'enemic que no te gens de muscul. Sembla confos...
      enemyReactionText: Que es un muscul? No em sona gens ni mica aquesta paraula...
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Explicar acudit
      playerActionText: Li dius en forma d'acudit a l'enemic que el seu menjar preferit
        son les costelles. No pot parar de riure.
      enemyReactionText: HAHAHAHA, clar, perque les costelles son un os de l'esquelet,
        HAHAHAHA
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 2
    enemyEntryText: HAHAHAHA, NO PUC PARAR DE RIURE!
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: Balles una mica per rematar l'assumpte. L'enemic queda impresionat.
      enemyReactionText: Ets molt versatil, com un anec! Ho pilles? Perque els anecs
        saben volar, nadar i caminar! HAHAHA
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: Comences a plorar  L'enemic es preocupa per tu...
      enemyReactionText: "Ei... tot b\xE9? Et puc ajudar amb alguna cosa?"
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Oferir os
      playerActionText: Alces amb la teva ma l'os que tenies a l'inventari. Abans
        de que puguis dir res, l'enemic te'l treu de la ma i sembla alegrar-se.
      enemyReactionText: Es un regal? Per a mi? Es lo millor que em podries haver
        donat
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insultar
      playerActionText: Li dius a l'enemic que no te gens de muscul. Sembla confos...
      enemyReactionText: Que es un muscul? No em sona gens ni mica aquesta paraula...
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Explicar acudit
      playerActionText: Li preguntes a l'enemic que perque els esquelets no van a
        classe. Abans de poder dir la resposta, ell et talla...
      enemyReactionText: Oh! Aquesta me la se, perque no tenen cap cap! HAHAHAHA
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
  - nodeId: 5
    enemyEntryText: "Que es all\xF2 que feies fa un moment?"
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: Balles amb mes confianca. Li dius a l'enemic que el que fas
        es diu "ballar"
      enemyReactionText: "Uaaaau, mai n'havia sentit a parlar! Deixa'm intentar-ho!
        Ho faig b\xE9?"
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: Comences a plorar despres de ballar. L'enemic esta confos
      enemyReactionText: "Ei... tot be? T'has tor\xE7at el tormell quan ballaves?"
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Oferir os
      playerActionText: Alces amb la teva ma l'os que tenies a l'inventari. Abans
        de que puguis dir res, l'enemic te'l treu de la ma i sembla alegrar-se.
      enemyReactionText: Es un regal? Per a mi? Es lo millor que em podries haver
        donat!
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insultar
      playerActionText: Li dius a l'enemic que no te gens de muscul. Sembla confos...
      enemyReactionText: Que es un muscul? No em sona gens ni mica aquesta paraula...
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Explicar acudit
      playerActionText: Li dius en forma d'acudit a l'enemic que el seu menjar preferit
        son les costelles. No pot parar de riure.
      enemyReactionText: HAHAHAHA, clar, perque les costelles son un os de l'esquelet,
        HAHAHAHA
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 6
    enemyEntryText: Que tal, em moc be?
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: 'Balles. L''enemic et segueix el rotllo, li dons un 10/10. '
      enemyReactionText: Crec que he trobat un nou passatemps preferit! I tot  gracies
        a tu!
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: "Comen\xE7es a plorar. L'enemic es preocupa per tu..."
      enemyReactionText: 'Ei... tot be? '
      nextNodeId: 6
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Oferir os
      playerActionText: Alces amb la teva ma l'os que tenies a l'inventari. Abans
        de que puguis dir res, l'enemic te'l treu de la ma i sembla alegrar-se.
      enemyReactionText: Es un regal? Per a mi? Es lo millor que em podries haver
        donat!
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insultar
      playerActionText: Li dius a l'enemic que no te gens de muscul. Sembla confos...
      enemyReactionText: Que es un muscul? No em sona gens ni mica aquesta paraula...
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Explicar acudit
      playerActionText: Li preguntes a l'enemic que perque els esquelets no van a
        classe. Abans de poder dir la resposta, ell respon...
      enemyReactionText: Oh! Aquesta me la se, perque no tenen cap cap! HAHAHAHA
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
  - nodeId: 7
    enemyEntryText: 'Tranquil Skell, nomes es una esgarrinxada... '
    defaultReactionText: ...
    enableApology: 1
    attackNextNodeId: 7
    transitions:
    - actionName: Ballar
      playerActionText: Balles. L'enemic desconfia de les teves accions.
      enemyReactionText: Acabare amb tu!
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: Plores. L'enemic desconfia de les teves accions.
      enemyReactionText: Acabare amb tu!
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Oferir os
      playerActionText: Li ofereixes un os a mode de disculpes a l'enemic. Sembla
        que ho accepta.
      enemyReactionText: Ho agraeixo, encara que fa un moment m'has intentat matar...
        pero, perdonable...
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Insultar
      playerActionText: Insultes al creador de l'enemic. No sembla afectar-li.
      enemyReactionText: M'ho esperava venint de tu.
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Explicar acudit
      playerActionText: Intentes deixar anar l'acudit mes divertit del mon, pero
        no se t'acudeix res...
      enemyReactionText: Oh vaja... quina mala sort, un torn de regal per a mi!
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Demanar Disculpes
      playerActionText: Demanes perdo pels teus actes agresius. L'enemic ho enten
        pero tampoc baixa la guardia.
      enemyReactionText: Entenc.. be, no passa res, pero ara a lluitar!
      nextNodeId: 0
      requiredItem: {fileID: 0}
