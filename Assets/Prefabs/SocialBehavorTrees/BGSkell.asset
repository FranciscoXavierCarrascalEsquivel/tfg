%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4961ccfa01b95f14ca6b59134965d3cf, type: 3}
  m_Name: BGSkell
  m_EditorClassIdentifier: Assembly-CSharp::SocialBehaviorTree
  playerActions:
  - Dance
  - Cry
  - Offer bone
  - Insult
  - Tell a joke
  menuHeader: 'Available Actions:'
  startNodeId: 0
  friendshipText: You are a good guy, thank you. Take this bone as a gift.
  friendGoldMin: 4
  friendGoldMax: 6
  nodes:
  - nodeId: 0
    enemyEntryText: Hey, why aren't you attacking me?
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: "You start dancing awkwardly, doing the first thing that
        comes to mind. The enemy seems curious to know what you\u2019re doing.\r\n"
      enemyReactionText: Hey! What's that? Some kind of forbidden technique?
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: "You throw yourself to the ground and start crying inconsolably...
        The enemy doesn\u2019t seem to care..."
      enemyReactionText: "Crying proves you\u2019re not a pure-hearted warrior...
        Get up and fight properly!"
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Insult
      playerActionText: You tell the enemy that they have no muscle at all... The
        enemy seems confused...
      enemyReactionText: What's a 'muscle'?
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Offer bone
      playerActionText: You raise the bone you had in your inventory with your hand.
        Before you can say anything, the enemy takes it from your hand and seems
        happy.
      enemyReactionText: "Is it a gift? For me? It\u2019s the best thing you could
        have given me."
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Tell a joke
      playerActionText: "You jokingly tell the enemy that skeletons don\u2019t go
        partying because they don\u2019t have the body to handle it. He start laughing."
      enemyReactionText: MUAHAHAHA! That's a rib-tickler! Literally!
      nextNodeId: 1
      requiredItem: {fileID: 0}
  - nodeId: 1
    enemyEntryText: HAHAHA, I'd drop dead if I wasn't already! HAHAHA!
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: You do a few flamenco steps. The enemy is surprised and keeps
        laughing.
      enemyReactionText: WOW, not only are you a good comedian, you can dance too?
        What talent!
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You start crying after telling the joke. The enemy finds
        it strange...
      enemyReactionText: "Yo... everything good at home? Maybe it wasn\u2019t a joke
        and I got it wrong... I\u2019m sorry..."
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Offer bone
      playerActionText: You raise the bone you had in your inventory with your hand.
        Before you can say anything, the enemy takes it from your hand and seems
        happy.
      enemyReactionText: "Is it a gift? For me? It\u2019s the best thing you could
        have given me."
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insult
      playerActionText: "You tell the enemy that they don\u2019t have any muscle
        at all. They seem confused..."
      enemyReactionText: "What's a \u201Cmuscle\u201D? That word doesn\u2019t ring
        a bell at all..."
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Tell a joke
      playerActionText: "You jokingly tell the enemy that their favorite food is
        ribs. They can\u2019t stop laughing."
      enemyReactionText: HAHAHAHA, of course, because ribs are bones in the skeleton,
        HAHAHAHA.
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 2
    enemyEntryText: MUAHAHAHA, I CAN'T BREATHE! WAIT, I DONT BREATHE ANYWAY!
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: You do a little victory moonwalk. The skeleton is mesmerized.
      enemyReactionText: "You\u2019re very versatile, like a duck! Get it? Because
        ducks can fly, swim, and walk! HAHAHA"
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: "Comences a plorar desconsoladament. L\u2019esquelet s\u2019acosta
        una mica m\xE9s."
      enemyReactionText: Hey... everything okay? Can I help you with anything?
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Offer bone
      playerActionText: You raise the bone you had in your inventory with your hand.
        Before you can say anything, the enemy takes it from your hand and seems
        happy.
      enemyReactionText: "Is it a gift? For me? It\u2019s the best thing you could
        have given me."
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insult
      playerActionText: "You tell the enemy that he don\u2019t have any muscle at
        all. he seem confused...\r\n"
      enemyReactionText: "What's a \u201Cmuscle\u201D? That word doesn\u2019t ring
        a bell at all..."
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Tell a joke
      playerActionText: "You ask the enemy why skeletons don\u2019t go to class.
        Before you can give the answer, they cut you off...\r\n"
      enemyReactionText: Oh! I know this one! Because their hearts aren't in it!
        HAHAHAHA!
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
  - nodeId: 5
    enemyEntryText: What was that thing you were doing a moment ago?
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: "You dance with more confidence. You tell the enemy that
        what you\u2019re doing is called \u201Cdancing.\u201D"
      enemyReactionText: "Woooow, I\u2019d never heard of it before! Let me try it!
        Am I doing it right?"
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You burst into tears mid-dance. The skeleton stands in awkward
        silence.
      enemyReactionText: Yo... everything good at home? Did you twist your ankle
        while you were dancing?
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Offer bone
      playerActionText: You raise the bone you had in your inventory with your hand.
        Before you can say anything, the enemy takes it from your hand and seems
        happy.
      enemyReactionText: "Is it a gift? For me? It\u2019s the best thing you could
        have given me!"
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insult
      playerActionText: "You tell the enemy that they don\u2019t have any muscle
        at all. They seem confused...\r\n"
      enemyReactionText: "What's a \u201Cmuscle\u201D? That word doesn\u2019t ring
        a bell at all..."
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Tell a joke
      playerActionText: Li dius en forma d'acudit a l'enemic que el seu menjar preferit
        son les costelles. No pot parar de riure.
      enemyReactionText: HAHAHAHA, clar, perque les costelles son un os de l'esquelet,
        HAHAHAHA
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 6
    enemyEntryText: How's my form? Do I got the moves like Jagger?
    defaultReactionText: ...
    enableApology: 0
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: You dance. The enemy plays along, and you give them a 10/10.
      enemyReactionText: "I think I\u2019ve found a new favorite hobby! And it\u2019s
        all thanks to you!"
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You start crying. The enemy gets worried about you...
      enemyReactionText: Yo... everything good at home?
      nextNodeId: 6
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Offer bone
      playerActionText: You raise the bone you had in your inventory with your hand.
        Before you can say anything, the enemy takes it from your hand and seems
        happy.
      enemyReactionText: "Is it a gift? For me? It\u2019s the best thing you could
        have given me!"
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insult
      playerActionText: "You tell the enemy that they don\u2019t have any muscle
        at all. They seem confused..."
      enemyReactionText: "What's a \u201Cmuscle\u201D? That word doesn\u2019t ring
        a bell at all..."
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Tell a joke
      playerActionText: "You ask the enemy why skeletons don\u2019t go to class.
        Before you can give the answer, they answer...\r\n"
      enemyReactionText: "Because they don\u2019t have a head for studying!"
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
  - nodeId: 7
    enemyEntryText: Ouch... that hurts...
    defaultReactionText: ...
    enableApology: 1
    attackNextNodeId: 7
    transitions:
    - actionName: Dance
      playerActionText: You start dancing, trying to soften the mood after the hit.
        The enemy looks at you with suspicion.
      enemyReactionText: "So... first you hit me, and now you want to throw a party?
        I don\u2019t know whether to laugh or get even angrier."
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You start crying uncontrollably, feeling sorry for the hit
        you gave them. The enemy seems confused.
      enemyReactionText: "Hey... now you\u2019re crying? But I\u2019m the one who
        got hit!"
      nextNodeId: 7
      requiredItem: {fileID: 0}
    - actionName: Offer bone
      playerActionText: You raise the bone from your inventory as a peace offering.
        The enemy looks at it, still a little annoyed.
      enemyReactionText: "Hmph... it\u2019s a good gift, I won\u2019t deny that.
        But it doesn\u2019t erase the fact that you hit me."
      nextNodeId: AMIC
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Insult
      playerActionText: You try to insult the enemy, but after hitting them, it sounds
        even worse. The enemy gets angry.
      enemyReactionText: Seriously? First you hit me, and now you insult me? You
        really want to lose this fight.
      nextNodeId: 7
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
    - actionName: Tell a joke
      playerActionText: "You tell the enemy a joke, trying to fix the situation.
        They try not to laugh, but it\u2019s difficult."
      enemyReactionText: "I\u2019m not going to laugh after what you did... wait...
        okay, that was kind of good."
      nextNodeId: 0
      requiredItem: {fileID: 11400000, guid: c029f67815947b24b8a3d0d258cf97f0, type: 2}
