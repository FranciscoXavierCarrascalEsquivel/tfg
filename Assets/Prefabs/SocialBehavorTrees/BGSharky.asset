      enemyReactionText: "Glup! (Gr\xE0cies)"
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Fer-se el mort
      playerActionText: Et tires dramaticament al terra per fingir la teva mort.
      enemyReactionText: Glup?? (Que estas fent?)
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 4
    enemyEntryText: Glup... Glup! (Aquest descobriment... pot ser or per mi i els
      meus amics!)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Demanar anecdota
      playerActionText: Li demanes a l'enemic si es que et pot explicar alguna anecdota
        per animar-te, ja que estas trist
      enemyReactionText: Glup! Glup (El que calgui per animar al dispensador d'aigua!
        Vaig perdre la meva aleta dorsal original en una aposta).
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Alagar
      playerActionText: "Mentres t'asseques les llagrimes, li dius a l'enemic que
        admira molt el seu f\xEDsic."
      enemyReactionText: Glup... (Uau, aixo no m'ho esperava, moltes gracies...)
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Plorar
      playerActionText: Intentes plorar mes, pero ja estas sec...
      enemyReactionText: Glup? (Aleshores, no es infinit?)
      nextNodeId: 4
