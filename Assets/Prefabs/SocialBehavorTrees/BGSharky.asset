      enemyReactionText: Glup? (Que estas fent?)
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 6
    enemyEntryText: Gluup... (Aguantaa...)
    defaultReactionText: Glup, glup...
    enableApology: 1
    attackNextNodeId: 6
    transitions:
    - actionName: Demanar anecdota
      playerActionText: Glup?! (Em colpeges i despres em demanes que t'expliqui la
