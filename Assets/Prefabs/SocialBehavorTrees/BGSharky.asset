MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4961ccfa01b95f14ca6b59134965d3cf, type: 3}
  m_Name: BGSharky
  m_EditorClassIdentifier: Assembly-CSharp::SocialBehaviorTree
  playerActions:
  - Ask for a story
  - Cry
  - Flatter
  - Scare
  - Play dead
  menuHeader: 'Available Actions:'
  startNodeId: 0
  friendshipText: '*Bows respectfully* Glup, glup, glup!'
  friendGoldMin: 7
  friendGoldMax: 10
  nodes:
  - nodeId: 0
    enemyEntryText: Glup! (Prepare to be filleted!)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: You ask the enemy if he can tell you an interesting anecdote.
      enemyReactionText: "What do you think this is, the village bar? I\u2019ll finish
        you off!"
      nextNodeId: 
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You cry, begging for mercy... Suddenly, the enemy notices
        and reacts.
      enemyReactionText: Whoa! Are you an infinite water generator? That's kinda
        rad.
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: You tell the enemy that their style is really cool, that
        you like their abs and their futuristic look. He turns as red as a tomato.
      enemyReactionText: 'Glup! Glup! Glup! Aww! Stop! No one has ever said such
        nice things to me before!) '
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: 'You move your open hand from side to side, trying to keep
        the enemy away.

'
      enemyReactionText: "What do you think I am, a fly? I\u2019m a shark with abs."
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup (Nice try, I invented that trick).
      nextNodeId: 0
      requiredItem: {fileID: 0}
  - nodeId: 1
    enemyEntryText: Glup... (Alright, that's enough...)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: 'You ask the enemy if they can tell you something about how
        they managed to get such an incredible physique.

'
      enemyReactionText: "Glup! Glup, glup, glup. (Oh! Well, you see, it\u2019s all
        based on a good diet and consistent exercise, but above all, a lot of willpower)."
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: "You cry, begging for mercy... The enemy doesn\u2019t even
        notice, as they are focused on doing a set of abdominal crunches."
      enemyReactionText: Glup, glup... (nine, ten, eleven...)
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: "You try to flatter the enemy even more, but you realize
        you\u2019ve already said it all before..."
      enemyReactionText: Glup? (Got anything else?)
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: "You move your open hand from side to side, trying to keep
        the enemy away. They think you\u2019re trying to help cool down his blushing."
      enemyReactionText: Glup! (Thank you!)
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup?? (Bruh, what in the ocean are you doing?)
      nextNodeId: 0
      requiredItem: {fileID: 0}
  - nodeId: 2
    enemyEntryText: Glup... Glup! (Wow, someone interested on my personal life!)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: You ask the shark for another story.
      enemyReactionText: Glup... (I would, but honestly, I have nothing else to explain).
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You cry because of the strong willpower the enemy has shown
        to achieve the physique many people would wish for.
      enemyReactionText: "Glup... (No one had ever felt so proud of something I\u2019ve
        done before...)"
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: "You try to flatter the enemy even more, but you realize
        you\u2019ve already said it all before..."
      enemyReactionText: Glup? (Got anything else?)
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: "You move your open hand from side to side, trying to keep
        the enemy away. They think you\u2019re trying to help ease their blushing."
      enemyReactionText: "Glup! (Gr\xE0cies)"
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup?? (Bruh, what in the ocean are you doing?)
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 4
    enemyEntryText: Glup... Glup! (This discovery can be gold for my friends and
      I!)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: You ask the enemy if they can tell you an anecdote to cheer
        you up, since you are sad.
      enemyReactionText: Glup! Glup (Whatever it takes to cheer up the water dispenser!
        I lost my original dorsal fin in a bet).
      nextNodeId: 5
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: While you dry your tears, you tell the enemy that you really
        admire their physique.
      enemyReactionText: Glup... (Wow... that hit me right in the feels. Thanks,
        bro.)
      nextNodeId: 1
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You try to cry more, but you are out of tears.
      enemyReactionText: Glup? (Wait, so you're not an infinite water glitch?)
      nextNodeId: 4
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: You move your open hand from side to side, trying to keep
        the enemy away.
      enemyReactionText: Glup? (What's with the funny hand waving?)
      nextNodeId: 4
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup? (What are you doing now?)
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 5
    enemyEntryText: Glup... (Nobody ever cared enough to ask about my past...)
    defaultReactionText: Glup, glup...
    enableApology: 0
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: You ask the enemy if they can explain how they achieved such
        a great physique.
      enemyReactionText: Glup, glup... (Blood, sweat, tears, and lots of plankton.)
      nextNodeId: 2
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: "You praise the enemy\u2019s bravery for betting a part of
        their body, even though it\u2019s not exactly recommended.\r\n"
      enemyReactionText: Glup... (Wow... that hit me right in the feels. Thanks,
        bro.)
      nextNodeId: AMIC
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You try to cry more, but you are out of tears.
      enemyReactionText: Glup? (Wait, so you're not an infinite water glitch?)
      nextNodeId: 4
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: You move your open hand from side to side, trying to keep
        the enemy away.
      enemyReactionText: Glup? (What's with the funny hand waving?)
      nextNodeId: 4
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup? (What are you doing?)
      nextNodeId: 2
      requiredItem: {fileID: 0}
  - nodeId: 6
    enemyEntryText: Gluup... (Hold the line...)
    defaultReactionText: Glup, glup...
    enableApology: 1
    attackNextNodeId: 6
    transitions:
    - actionName: Ask for a story
      playerActionText: Glup?! (You hit me and then ask me to tell you my life story?)
      enemyReactionText: Glup, glup... (Blood, sweat, tears, and lots of plankton.)
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Flatter
      playerActionText: "You praise the opponent\u2019s toughness for withstanding
        the hit you just gave them. They don\u2019t seem very happy."
      enemyReactionText: Glup? (What am I, a crash test dummy?)
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Cry
      playerActionText: You cry, deeply regretting the violence...
      enemyReactionText: "Glup...glup? (You felt bad... so maybe you\u2019re not
        completely evil after all?)"
      nextNodeId: 0
      requiredItem: {fileID: 0}
    - actionName: Scare
      playerActionText: You move your open hand from side to side, trying to keep
        the enemy away.
      enemyReactionText: "Glup? (Do you think you\u2019ll achieve anything by moving
        your hand like that?)"
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Play dead
      playerActionText: You dramatically flop to the floor, playing dead.
      enemyReactionText: Glup! (Keep playing dead, soon you won't have to act!)
      nextNodeId: 6
      requiredItem: {fileID: 0}
    - actionName: Apologize
      playerActionText: You apologize for your sudden outburst of violence.
      enemyReactionText: "Glup, glup (Okay, but why are you telling me this? We\u2019re
        in the middle of a fight)"
      nextNodeId: 0
      requiredItem: {fileID: 0}
